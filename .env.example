# Skopiuj do .env i dostosuj. Po zmianie TARGET: restart Metro.
# Albo bez edycji .env:  npm run start:local  /  npm run start:staging

# --- przełącznik środowiska ---
# local  = LAN (Twój PC z artisan serve)
# staging = dartscore.studiokam.pl
EXPO_PUBLIC_API_TARGET=local

# IP komputera w sieci Wi‑Fi (tylko dla local)
EXPO_PUBLIC_LOCAL_HOST=192.168.0.28

# Opcjonalny pełny override (EAS / custom). Gdy ustawisz TARGET, preset i tak
# wygrywa przy npm run start:local|staging (skrypt czyści te zmienne).
# EXPO_PUBLIC_API_URL=https://dartscore.studiokam.pl/api
# EXPO_PUBLIC_REVERB_APP_KEY=28e001f35df29406bc8a144a39a4ef4a
# EXPO_PUBLIC_REVERB_SCHEME=https
# EXPO_PUBLIC_REVERB_PORT=443
# EXPO_PUBLIC_REVERB_DEBUG=true
