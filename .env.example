# Skopiuj do .env i dostosuj. Po zmianie: restart Metro (`npm start`).

# Dev (LAN) — IP komputera z backendem
EXPO_PUBLIC_API_URL=http://192.168.0.28:8000/api

# Staging / prod (krok 6.4)
# EXPO_PUBLIC_API_URL=https://staging.example.com/api

# Reverb — domyślnie host wyciągany z API URL; opcjonalnie nadpisz:
# EXPO_PUBLIC_REVERB_APP_KEY=sld-reverb-key
# EXPO_PUBLIC_REVERB_HOST=staging.example.com
# EXPO_PUBLIC_REVERB_PORT=443
# EXPO_PUBLIC_REVERB_SCHEME=https
# EXPO_PUBLIC_REVERB_DEBUG=true

# Gotowy blok staging (skopiuj do .env — patrz eas.json preview):
# EXPO_PUBLIC_API_URL=https://dartscore.studiokam.pl/api
# EXPO_PUBLIC_REVERB_APP_KEY=28e001f35df29406bc8a144a39a4ef4a
# EXPO_PUBLIC_REVERB_SCHEME=https
# EXPO_PUBLIC_REVERB_PORT=443
# EXPO_PUBLIC_REVERB_DEBUG=true
